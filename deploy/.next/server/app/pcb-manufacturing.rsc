00","children":1}],["$","div",null,{"className":"translate-y-1","children":[["$","h3",null,{"className":"text-[17px] font-bold text-gray-900 mb-2 leading-tight","children":"PCB CAM processing"}],["$","p",null,{"className":"text-[15px] font-medium text-gray-600 leading-[1.8]","children":"The first step is CAM processing of PCB and Generating Gerber files because before the manufacturing starts it is very important to have a design. It acts as a blueprint in the manufacturing process. There are many PCB Designing Tools like EAGLE, KiCAD, etc. All the guides on how to generate Gerber files from various Designing Tools is available in our User-Guides."}]]}]]}],["$","div","1",{"className":"flex gap-6 group","children":[["$","div",null,{"className":"w-12 h-12 rounded-2xl bg-orange-50/80 border border-orange-100 flex items-center justify-center text-[#ff6b00] font-black text-lg shrink-0 group-hover:bg-[#ff6b00] group-hover:text-white transition-colors duration-300","children":2}],["$","div",null,{"className":"translate-y-1","children":[["$","h3",null,{"className":"text-[17px] font-bold text-gray-900 mb-2 leading-tight","children":"PCB bare board preparation"}],["$","p",null,{"className":"text-[15px] font-medium text-gray-600 leading-[1.8]","children":"Once the design is ready we will know the required board area. Bare boards are then cut according to that board area."}]]}]]}],["$","div","2",{"className":"flex gap-6 group","children":[["$","div",null,{"className":"w-12 h-12 rounded-2xl bg-orange-50/80 border border-orange-100 flex items-center justify-center text-[#ff6b00] font-black text-lg shrink-0 group-hover:bg-[#ff6b00] group-hover:text-white transition-colors duration-300","children":3}],["$","div",null,{"className":"translate-y-1","children":[["$","h3",null,{"className":"text-[17px] font-bold text-gray-900 mb-2 leading-tight","children":"Drilling the boards with excellon drill data"}],["$","p",null,{"className":"text-[15px] font-medium text-gray-600 leading-[1.8]","children":"Holes are drilled on the bare board by locating their exact drill spots. This is done using the Gerber files. These holes are drilled to expose the surface and inner panels of the board."}]]}]]}],["$","div","3",{"className":"flex gap-6 group","children":[["$","div",null,{"className":"w-12 h-12 rounded-2xl bg-orange-50/80 border border-orange-100 flex items-center justify-center text-[#ff6b00] font-black text-lg shrink-0 group-hover:bg-[#ff6b00] group-hover:text-white transition-colors duration-300","children":4}],["$","div",null,{"className":"translate-y-1","children":[["$","h3",null,{"className":"text-[17px] font-bold text-gray-900 mb-2 leading-tight","children":"Plating through the hole"}],["$","p",null,{"className":"text-[15px] font-medium text-gray-600 leading-[1.8]","children":"Since the holes are drilled in the board there is no way for the current to pass through all the layers, that's when Plating through the hole comes in the picture. Copper is deposited on the inner surfaces of the holes which helps the current to flow through all the layers."}]]}]]}],["$","div","4",{"className":"flex gap-6 group","children":[["$","div",null,{"className":"w-12 h-12 rounded-2xl bg-orange-50/80 border border-orange-100 flex items-center justify-center text-[#ff6b00] font-black text-lg shrink-0 group-hover:bg-[#ff6b00] group-hover:text-white transition-colors duration-300","children":5}],["$","div",null,{"className":"translate-y-1","children":[["$","h3",null,{"className":"text-[17px] font-bold text-gray-900 mb-2 leading-tight","children":"Applying negative circuit patterns on PCB"}],["$","p",null,{"className":"text-[15px] font-medium text-gray-600 leading-[1.8]","children":"Then using the Gerber files as a blueprint, all the negative circuit patterns are applied on the Printed circuit board using ink."}]]}]]}],["$","div","5",{"className":"flex gap-6 group","children":[["$","div",null,{"className":"w-12 h-12 rounded-2xl bg-orange-50/80 border border-orange-100 flex i